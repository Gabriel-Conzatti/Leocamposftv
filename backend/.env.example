PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/futevolei_db

# JWT
JWT_SECRET=sua_chave_secreta_super_segura_aqui_mude_em_producao
JWT_EXPIRE=7d

# Email Configuration (SMTP para enviar notificações)
# Recomendado: Gmail (com senha de app), SendGrid ou Mailgun
# Veja EMAIL_SETUP.md para instruções detalhadas
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-com-16-caracteres

# Mercado Pago (obtenha em https://www.mercadopago.com/developers)
MERCADO_PAGO_ACCESS_TOKEN=seu_access_token_aqui
MERCADO_PAGO_PUBLIC_KEY=sua_chave_publica_aqui

# Frontend URL
FRONTEND_URL=http://localhost:5173
